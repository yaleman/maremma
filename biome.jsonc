{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noUnknownAtRules": {
          "level": "error",
          "options": {
            "ignore": [
              "tailwind"
            ]
          }
        }
      }
    }
  }
}